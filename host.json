{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    }
  },
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  },
  "extensions": {
    "http": {
      "maxConcurrentRequests": 5,
      "maxOutstandingRequests": 50,
      "dynamicThrottlesEnabled": true
    }
  },
  "functionTimeout": "00:02:00",
  "aggregator": {
    "batchSize": 1000,
    "flushTimeout": "00:00:30"
  }
}